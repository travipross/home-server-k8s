*.key
*.agekey
*secret.yaml
*.env
!*.example.env

# ignore files ending with .sops.yaml extension, as a convention to indicate they contain secrets
*.sops.yaml

# track the file named .sops.yaml as it is a config file used by sops CLI
!.sops.yaml

# Ignore files that are dumped for inspecting helm chart default values
*-default-values.yaml

# Ignore various manifests marked as examples
*-example.yaml

# Ignore sensitive terraform values
.terraform/
*.tfstate*
.terraform.lock.hcl
*.auto.tfvars

# Ignore Cloudflare CLI cache
.wrangler/